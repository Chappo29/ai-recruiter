# Copy to .env and adjust (do not commit .env).
# Default matches docker-compose.yml (user/password postgres/postgres).

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruiter

# Required — no defaults in production code
# CRITICAL: Must be at least 32 characters! Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
INTERNAL_API_KEY=change-me-use-openssl-rand-hex-32

ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Public self-service registration (set false for invite-only)
REGISTRATION_ENABLED=true

# CORS (comma-separated origins; credentials enabled — do not use *)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend URL for Telegram bot callbacks
BACKEND_URL=http://localhost:8000

# Bot-worker control API (run: python -m bot)
BOT_WORKER_URL=http://127.0.0.1:8001
BOT_WORKER_HOST=127.0.0.1
BOT_WORKER_PORT=8001

# Rate limiting (slowapi; per client IP unless noted)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TEAM=30/minute
RATE_LIMIT_SCREENINGS=60/minute
RATE_LIMIT_PARSE_HH=20/minute
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=5/hour
RATE_LIMIT_INTERNAL=120/minute
RATE_LIMIT_HEALTH=120/minute
# RATE_LIMIT_STORAGE_URI=memory://

# File upload limits (MB)
MAX_RESUME_SIZE_MB=10
MAX_AVATAR_SIZE_MB=5
MAX_PDF_PAGES=30

# LLM settings (Ollama) — PR #1 hardening
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SEC=300
OLLAMA_TEMPERATURE=0
OLLAMA_TOP_P=0.9
# OLLAMA_SEED=42
LLM_MAX_RETRIES=3
LLM_PROMPT_VERSION=v1-hardening

# Code-computed verdict thresholds (no auto-reject on status)
SCORE_FIT_MIN=75
SCORE_MAYBE_MIN=50

# Later PRs (keep false until enabled)
SCREENING_RUBRIC_PIPELINE=false
SCREENING_SHADOW_MODE=false
STRUCTURED_INTERVIEW=false

# Default values
DEFAULT_FEEDBACK_DAYS=3

# Telegram bot: min seconds between messages from the same user
BOT_RATE_LIMIT_SEC=1.0

# Passwords with @, #, spaces, Cyrillic, etc. must be URL-encoded in the URL.
# Encode only the password segment, e.g. in Python:
#   from urllib.parse import quote_plus
#   password = quote_plus("Ш_Ь")
#   url = f"postgresql+asyncpg://postgres:{password}@localhost:5432/recruiter"
