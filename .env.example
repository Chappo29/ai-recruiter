# Copy to .env and adjust (do not commit .env).
# Default matches docker-compose.yml (user/password postgres/postgres).

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruiter

# Required — no defaults in production code
SECRET_KEY=change-me-use-openssl-rand-hex-32
INTERNAL_API_KEY=change-me-use-openssl-rand-hex-32

ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins; credentials enabled — do not use *)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend URL for Telegram bot callbacks
BACKEND_URL=http://localhost:8000

# Bot-worker control API (run: python -m bot)
BOT_WORKER_URL=http://127.0.0.1:8001
BOT_WORKER_HOST=127.0.0.1
BOT_WORKER_PORT=8001

# Rate limiting (slowapi; per client IP unless noted)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REGISTER=5/hour
RATE_LIMIT_INTERNAL=120/minute
RATE_LIMIT_HEALTH=120/minute
# RATE_LIMIT_STORAGE_URI=memory://

# Passwords with @, #, spaces, Cyrillic, etc. must be URL-encoded in the URL.
# Encode only the password segment, e.g. in Python:
#   from urllib.parse import quote_plus
#   password = quote_plus("Ш_Ь")
#   url = f"postgresql+asyncpg://postgres:{password}@localhost:5432/recruiter"
